---
import { NAV_ITEMS, TABBED_CONTENT_ID, PHONE_NUMBER } from '../lib/constants';
---
<header id="main-nav" class="fixed top-0 left-0 right-0 z-40 transition-all duration-200">
  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 lg:h-[4.25rem]" aria-label="Main navigation">
      <a href="#" class="font-semibold text-white text-[0.9375rem] tracking-tight">BMP: Build. Manage. Perform.</a>
      <button
        type="button"
        id="nav-menu-toggle"
        class="lg:hidden p-2.5 rounded-md text-zinc-400 hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <div id="nav-menu" class="hidden lg:flex items-center gap-10">
        {NAV_ITEMS.map((item) => (
          <a
            href={`#${TABBED_CONTENT_ID}`}
            class="nav-link text-zinc-400 hover:text-white text-[0.8125rem] font-medium tracking-wide uppercase transition-colors"
            data-tab={item.id}
          >
            {item.label}
          </a>
        ))}
        <a
          href={`tel:${PHONE_NUMBER}`}
          class="inline-flex items-center rounded-lg bg-white text-zinc-900 px-6 py-2.5 text-sm font-semibold hover:bg-zinc-200 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-white"
        >
          {PHONE_NUMBER}
        </a>
      </div>
    </nav>
  </div>
  <div id="nav-menu-dropdown" class="hidden lg:hidden absolute top-full left-0 right-0 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-800/50">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col gap-1">
      {NAV_ITEMS.map((item) => (
        <a
          href={`#${TABBED_CONTENT_ID}`}
          class="nav-link py-2.5 text-zinc-400 hover:text-white text-sm font-medium transition-colors"
          data-tab={item.id}
        >
          {item.label}
        </a>
      ))}
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center justify-center py-3 mt-2 rounded-lg bg-white text-zinc-900 text-sm font-semibold hover:bg-zinc-200 transition-colors"
      >
        {PHONE_NUMBER}
      </a>
    </div>
  </div>
</header>

<script define:vars={{ TABBED_CONTENT_ID }}>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('nav-menu-toggle');
  const dropdown = document.getElementById('nav-menu-dropdown');

  function updateNavScroll() {
    if (!nav) return;
    if (window.scrollY > 16) {
      nav.classList.add('bg-zinc-950/90', 'backdrop-blur-sm', 'border-b', 'border-zinc-800/50');
    } else {
      nav.classList.remove('bg-zinc-950/90', 'backdrop-blur-sm', 'border-b', 'border-zinc-800/50');
    }
  }

  window.addEventListener('scroll', updateNavScroll);
  updateNavScroll();

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    dropdown?.classList.toggle('hidden', expanded);
  });

  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      const tabId = link.getAttribute('data-tab');
      if (tabId) {
        const event = new CustomEvent('nav-tab-change', { detail: { tabId } });
        window.dispatchEvent(event);
      }
      dropdown?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
