---
import { PHONE_NUMBER } from '../lib/constants';
---
<section class="min-h-screen flex items-center px-6 lg:px-8 pt-20">
  <div class="max-w-4xl w-full mx-auto">
    <div class="inline-flex items-center gap-2 rounded-full border border-zinc-700/50 bg-zinc-800/50 px-4 py-1.5 text-sm text-zinc-400 mb-8">
      <span class="relative flex h-2 w-2" aria-hidden="true">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      AI-Powered
    </div>
    <p class="text-[0.6875rem] font-medium tracking-[0.2em] text-zinc-500 uppercase mb-6">
      Build-Operate-Transfer and Executive Leadership
    </p>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight bg-gradient-to-r from-white via-zinc-300 to-zinc-500 bg-clip-text text-transparent mb-2 leading-[1.15]">
      BMP: Build. Manage. Perform.
    </h1>
    <p class="text-lg md:text-xl text-zinc-400 leading-relaxed font-medium mb-6">
      Romania Hub Launchpad
    </p>
    <p class="text-base text-zinc-400 mb-1 font-medium">
      1. Managing Director as a Service
    </p>
    <p class="text-base text-zinc-400 mb-8 font-medium">
      2. Build → Operate → Transfer (BOT)
    </p>
    <p class="text-zinc-400 text-[0.9375rem] leading-relaxed mb-10 max-w-2xl">
      We build and operate Romania delivery hubs with executive governance—powered by AI-assisted operations.
    </p>
    <div class="flex flex-wrap gap-2 mb-12">
      <span class="rounded-full bg-zinc-800/60 border border-zinc-700/40 px-3 py-1 text-sm text-zinc-400">8-week launch: hiring pipeline, setup, operating cadence</span>
      <span class="rounded-full bg-zinc-800/60 border border-zinc-700/40 px-3 py-1 text-sm text-zinc-400">Executive governance: KPIs, risk and decision logs</span>
      <span class="rounded-full bg-zinc-800/60 border border-zinc-700/40 px-3 py-1 text-sm text-zinc-400">AI-enabled operations: faster recruiting, clearer reporting</span>
    </div>
    <div class="flex flex-col sm:flex-row gap-3 mb-20">
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center justify-center gap-2.5 rounded-lg bg-white text-zinc-900 px-8 py-3 text-base font-semibold hover:bg-zinc-200 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-zinc-900 focus:ring-white"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        {PHONE_NUMBER}
      </a>
    </div>
    <div class="pt-6 border-t border-zinc-800/50 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-600 tracking-wide">
      <span>Delivery</span>
      <span class="text-zinc-700" aria-hidden="true">·</span>
      <span>Operations</span>
      <span class="text-zinc-700" aria-hidden="true">·</span>
      <span>Scaling</span>
      <span class="text-zinc-700" aria-hidden="true">·</span>
      <span>Governance</span>
      <span class="text-zinc-700" aria-hidden="true">·</span>
      <span>AI enablement</span>
    </div>
  </div>
</section>
